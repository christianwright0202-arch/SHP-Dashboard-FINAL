# ============================================================
#  COPY THIS FILE TO ".env"  AND FILL IN YOUR OWN VALUES.
#  (In Vercel you paste these same values into Settings >
#   Environment Variables instead of using a file.)
# ============================================================

# --- Anthropic (powers Today's Focus, Alerts chat, Ask the Board, Events) ---
# Get this from https://console.anthropic.com  (Settings > API Keys)
# This one is SERVER-SIDE only. Never put it in a VITE_ variable.
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxx

# --- Supabase (cross-device data storage) ---
# Get these from your Supabase project: Settings > API
VITE_SUPABASE_URL=https://yourproject.supabase.co
VITE_SUPABASE_ANON_KEY=eyJxxxxxxxxxxxxxxxxxxxxxxxx

# --- Password (set BOTH to the SAME value) ---
# VITE_ version guards the screen; the plain one guards the API endpoint.
VITE_APP_PASSWORD=choose-a-password
APP_PASSWORD=choose-a-password
